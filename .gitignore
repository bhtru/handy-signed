# macOS
.DS_Store

# Build artifacts (regenerated by build.sh — never committed)
*.app/
*.dmg
*.icns
*.iconset/
/build/
/dist/

# Signing material — MUST never be committed to a public repo
*.p12
*.pem
*.cer
*.certSigningRequest
ExportOptions.plist

# Sparkle signing keys — private key lives in the Keychain, never in git
sparkle_private_key*
dsa_priv.pem

# Vendored frameworks (fetched by build.sh) and release staging
vendor/
releases/
