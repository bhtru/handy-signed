<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      App extensions MUST be sandboxed — pkd (the extension host) refuses to
      launch an unsandboxed .appex, no matter how the app is distributed.
      Removing app-sandbox silently kills every right-click menu item.

      The temporary-exception below grants filesystem access from inside the
      sandbox (extract zips, create files, run /usr/bin/open). It would be
      rejected by App Store review, but this app ships via Developer ID where
      it is allowed — do not "clean it up".
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
    <string>/</string>
</dict>
</plist>
