---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Handy - Windows-style Finder tools for macOS',
  description = 'Handy adds power-user Finder shortcuts and small system utilities to macOS, including cut and paste, Return to open, Copy Path, Open in Terminal, and more.',
  currentPath = Astro.url.pathname,
} = Astro.props;

const pageTitle = title === 'Handy'
  ? 'Handy - Windows-style Finder tools for macOS'
  : `${title} - Handy`;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/#features', label: 'Features' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://github.com/IsaacYeung/Handy/releases/latest', label: 'Releases' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://p.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/myr8ieo.css" />
    <link rel="icon" href="/assets/handy-mark.svg" type="image/svg+xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HM7NLM2BEP" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-HM7NLM2BEP');
    </script>
    <script type="text/javascript" is:inline>
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xqzwwpvk6h");
    </script>
  </head>
  <body>
    <header class="site-header" aria-label="Primary">
      <a class="brand" href="/">
        <img src="/assets/handy-mark.svg" alt="" width="34" height="34" />
        <span>Handy</span>
      </a>
      <nav>
        {navItems.map((item) => (
          <a
            href={item.href}
            aria-current={item.href === currentPath ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </header>

    <slot />

    <Footer currentPath={currentPath} />
  </body>
</html>
