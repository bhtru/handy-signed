---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FinderPreview from '../components/FinderPreview.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout title="Handy">
  <main>
    <section class="hero">
      <FinderPreview />

      <div class="hero-copy">
        <p class="eyebrow">macOS 13+ menu-bar utility</p>
        <h1>Handy</h1>
        <p class="lede">Finder shortcuts and small system controls for people who miss the fast parts of Windows.</p>
        <div class="actions">
          <a class="button primary" href="https://github.com/IsaacYeung/Handy/releases/latest/download/Handy.dmg">Download for macOS</a>
          <a class="button secondary" href="https://github.com/IsaacYeung/Handy">View source</a>
        </div>
        <p class="note">Developer ID signed releases require macOS Ventura or later.</p>
      </div>
    </section>

    <section id="features" class="feature-band" aria-labelledby="features-heading">
      <div class="section-heading">
        <p class="eyebrow">What it adds</p>
        <h2 id="features-heading">Small Finder changes that remove daily friction.</h2>
      </div>
      <div class="feature-grid">
        <article>
          <span>01</span>
          <h3>Cut and paste files</h3>
          <p>Use Command-X and Command-V in Finder to move files with undo support.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Return opens files</h3>
          <p>Press Return to open selected items while Shift-Return keeps rename close by.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Context menu helpers</h3>
          <p>Copy Path, Open in Terminal, New .txt File Here, and Extract All Here live where you right-click.</p>
        </article>
        <article>
          <span>04</span>
          <h3>System toggles</h3>
          <p>Keep Awake, hidden files, dark mode, Bluetooth sleep behavior, and Empty Trash sit in one quiet utility.</p>
        </article>
      </div>
    </section>

    <section id="setup" class="setup-band" aria-labelledby="setup-heading">
      <div>
        <p class="eyebrow">Install once</p>
        <h2 id="setup-heading">Drag to Applications, then grant only the permissions you use.</h2>
      </div>
      <ol class="steps">
        <li><span>1</span>Download the DMG and move Handy into Applications.</li>
        <li><span>2</span>Enable the Finder Extension for right-click tools.</li>
        <li><span>3</span>Grant Accessibility and Finder Automation for keyboard shortcuts.</li>
      </ol>
    </section>

    <section class="blog-preview" aria-labelledby="blog-preview-heading">
      <div class="section-heading">
        <p class="eyebrow">Updates</p>
        <h2 id="blog-preview-heading">Release notes and power-user notes.</h2>
      </div>
      <div class="post-list compact">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}/`}>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
      <a class="text-link" href="/blog">Read the blog</a>
    </section>
  </main>
</BaseLayout>
